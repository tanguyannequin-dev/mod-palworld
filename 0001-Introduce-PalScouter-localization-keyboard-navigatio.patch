+    if cfg_lang and L.dict[cfg_lang] then
+        return cfg_lang
+    end
+    return "en"
+end
+
+function L.t(key, cfg_lang)
+    local lang = L.get_current_lang(cfg_lang)
+    local t_table = L.dict[lang] or L.dict["en"]
+    return t_table[key] or L.dict["en"][key] or key
+end
